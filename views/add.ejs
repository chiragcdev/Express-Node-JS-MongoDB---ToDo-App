<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/bootstrap.min.css">
    <link href="/css/style.css" rel="stylesheet">
    <title>Add Todo</title>
</head>
<body>
    <%- include('navbar') %>
    <div class="container">
        <div class="col-md-6 offset-md-3">
            <h1 class="mt-4 mb-4">Add New Task</h1>
            <form class="box-shadow" action="/add" method="POST">
                <div class="mb-3">
                    <input type="text" class="form-control" id="title" placeholder="Enter task title" name="title">
                </div>
                <div class="mb-3">
                    <textarea class="form-control" id="description" rows="5" placeholder="Enter task description" name="description"></textarea>
                </div>
                <div class="col-md-12">
                    <button type="submit" class="btn btn-primary full-width">Add Task</button>
                </div>
            </form>
        </div>
    </div>
   

    <script src="/bootstrap.bundle.min.js"></script>
</body>
</html>