<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/bootstrap.min.css">
    <link href="/css/style.css" rel="stylesheet">
    <title>Todo List</title>
</head>
<body>
    <%- include('navbar') %>
    <div class="container">
        <form action="/multi-delete" method="post" class="bg-grey">
            <div class="col-md-8 offset-md-2">
                <div class="row">
                    <div class="d-flex justify-content-between align-items-center">
                        <h1 class="mt-4 mb-4">Task List</h1>
                        <button class="btn btn-primary">Delete Selected Tasks</button>
                    </div>
                    <% for (let task=0; task<result.length; task++) {%>
                        <div class="col-md-6">
                            <div class="card border-dark mb-4">
                                <div class="card-header"><%= result[task].title %></div>
                                <div class="card-body">
                                    <p class="card-text"><%= result[task].description %></p>
                                    <div class="d-flex">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="selectedTask" value="<%= result[task]._id %>" id="">
                                        </div>
                                        <a href="/delete/<%= result[task]._id %>" class="btn btn-sm btn-danger">Delete</a>
                                        <a href="/update/<%= result[task]._id %>" class="btn btn-sm btn-info">Update</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>  
                </div>
            </div>
        </form>
    </div>
    <script src="/bootstrap.bundle.min.js"></script>
</body>
</html>